PROJECT_DIRS := \
	libElaraCore \
	libElaraDebug \
	libElaraThreads \
	libElaraEncryption \
	libElaraEvent \
	libElaraFormat \
	libElaraIO \
	libElaraData \
	libElaraSockets \
	libElaraVector \
	libElaraUI \
	libElaraUiRpc \
	libElaraPythonThreads \
	libElaraParallelAssembly \
	libElaraSerializer \
	ElaraUnitTests \
	ElaraProjectBuilder \
	ElaraCppLint

ROOT_BUILD_DIR ?= $(abspath ./build)
INSTALL_ROOT_DIR ?= /usr/local
BUILD_PROJECTS := @BUILD_PROJECTS@
DISABLED_PROJECTS := @DISABLED_PROJECTS@
LIBELARADATA_CONFIGURE_FLAGS := @LIBELARADATA_CONFIGURE_FLAGS@
LIBELARAFORMAT_CONFIGURE_FLAGS := @LIBELARAFORMAT_CONFIGURE_FLAGS@
BUILD_PROFILE ?= release

COMMON_CFLAGS := -std=gnu++11
COMMON_WARNINGS := -Wall -Wextra -Wformat=2 -Wnull-dereference -Wimplicit-fallthrough
DEBUG_CFLAGS := $(COMMON_CFLAGS) $(COMMON_WARNINGS) -O0 -g3
RELEASE_CFLAGS := $(COMMON_CFLAGS) -O3 -DNDEBUG
ASAN_CFLAGS := $(COMMON_CFLAGS) $(COMMON_WARNINGS) -O1 -g3 -fno-omit-frame-pointer -fsanitize=address,undefined

COMMON_LDFLAGS :=
DEBUG_LDFLAGS := $(COMMON_LDFLAGS)
RELEASE_LDFLAGS := $(COMMON_LDFLAGS)
ASAN_LDFLAGS := $(COMMON_LDFLAGS) -fsanitize=address,undefined

ifeq ($(BUILD_PROFILE),debug)
TOOLCHAIN_CFLAGS := $(DEBUG_CFLAGS)
TOOLCHAIN_LDFLAGS := $(DEBUG_LDFLAGS)
else ifeq ($(BUILD_PROFILE),release)
TOOLCHAIN_CFLAGS := $(RELEASE_CFLAGS)
TOOLCHAIN_LDFLAGS := $(RELEASE_LDFLAGS)
else ifeq ($(BUILD_PROFILE),asan)
TOOLCHAIN_CFLAGS := $(ASAN_CFLAGS)
TOOLCHAIN_LDFLAGS := $(ASAN_LDFLAGS)
else
$(error Unsupported BUILD_PROFILE '$(BUILD_PROFILE)'. Use debug, release, or asan)
endif

CONFIGURE_DIRS := $(foreach dir,$(PROJECT_DIRS),$(if $(wildcard $(dir)/configure.ac),$(dir)))
BUILDABLE_DIRS := $(foreach dir,$(PROJECT_DIRS),$(if $(wildcard $(dir)/configure.ac)$(wildcard $(dir)/Makefile),$(dir)))
BUILD_STATE_FILE := .build-state
SMOKE_SCRIPT := ./tools/smoke_generated_projects.sh
HEADER_STAGE_DIRS := \
	libElaraCore/libelaracore:libelaracore \
	libElaraDebug/libelaradebug:libelaradebug \
	libElaraThreads/libelarathreads:libelarathreads \
	libElaraEncryption/libelaraencryption:libelaraencryption \
	libElaraEvent/libelaraevent:libelaraevent \
	libElaraFormat/libelaraformat:libelaraformat \
	libElaraIO/libelaraio:libelaraio \
	libElaraData/libelaradata:libelaradata \
	libElaraSockets/libelarasockets:libelarasockets \
	libElaraVector/libelaravector:libelaravector \
	libElaraVector/libelaravectorcpp:libelaravectorcpp \
	libElaraUI/libelaraui:libelaraui \
	libElaraUiRpc/libelarauirpc:libelarauirpc \
	libElaraPythonThreads/libelarapythonthreads:libelarapythonthreads \
	libElaraParallelAssembly/src:libelaraparallelassembly \
	libElaraSerializer/elaraserializer:libelaraserializer

.PHONY: all clean install remove cleanconf list preflight stage-headers smoke smoke-project-builder-cli $(PROJECT_DIRS)

all: preflight stage-headers $(BUILD_PROJECTS)

libElaraThreads: libElaraCore
libElaraIO: libElaraCore libElaraThreads
libElaraDebug: libElaraCore libElaraThreads libElaraIO
libElaraEncryption: libElaraCore libElaraDebug
libElaraEvent: libElaraCore libElaraDebug libElaraThreads
libElaraFormat: libElaraCore libElaraIO
libElaraData: libElaraCore
libElaraSockets: libElaraCore libElaraDebug libElaraThreads libElaraEvent
libElaraUI: libElaraCore libElaraThreads libElaraFormat libElaraIO libElaraVector
libElaraUiRpc: libElaraCore libElaraThreads libElaraFormat libElaraSockets libElaraUI
libElaraPythonThreads: libElaraCore libElaraThreads
libElaraParallelAssembly: libElaraCore
libElaraSerializer: libElaraCore
ElaraUnitTests: libElaraCore libElaraDebug
ElaraProjectBuilder: libElaraCore libElaraIO
ElaraCppLint: libElaraCore libElaraIO
$(PROJECT_DIRS): stage-headers

preflight:
	@if [ -n "$(DISABLED_PROJECTS)" ]; then \
		echo "Disabled projects: $(DISABLED_PROJECTS)"; \
	fi
	@mkdir -p "$(ROOT_BUILD_DIR)/include" "$(ROOT_BUILD_DIR)/lib" "$(ROOT_BUILD_DIR)/bin"

stage-headers: preflight
	@for mapping in $(HEADER_STAGE_DIRS); do \
		src="$${mapping%%:*}"; \
		dst_name="$${mapping##*:}"; \
		case " $(BUILD_PROJECTS) " in \
			*" $${src%%/*} "*) ;; \
			*) continue ;; \
		esac; \
		if [ -d "$$src" ]; then \
			find "$$src" -type f -name '*.h' | while IFS= read -r header; do \
				rel="$${header#$$src/}"; \
				dst="$(ROOT_BUILD_DIR)/include/$$dst_name/$$rel"; \
				mkdir -p "$$(dirname "$$dst")"; \
				cp "$$header" "$$dst" || exit $$?; \
			done || exit $$?; \
		fi; \
	done

$(PROJECT_DIRS):
	@if [ -f "$@/configure.ac" ]; then \
		configure_args=""; \
		case "$@" in \
			libElaraFormat) configure_args="$(LIBELARAFORMAT_CONFIGURE_FLAGS)" ;; \
			libElaraData) configure_args="$(LIBELARADATA_CONFIGURE_FLAGS)" ;; \
		esac; \
		if [ ! -x "$@/configure" ]; then \
			echo "Generating $@/configure"; \
			(cd "$@" && autoreconf -fi); \
		fi; \
		echo "Configuring $@"; \
		(cd "$@" && ./configure $$configure_args); \
	fi
	@if [ -f "$@/Makefile" ]; then \
		configure_args=""; \
		case "$@" in \
			libElaraFormat) configure_args="$(LIBELARAFORMAT_CONFIGURE_FLAGS)" ;; \
			libElaraData) configure_args="$(LIBELARADATA_CONFIGURE_FLAGS)" ;; \
		esac; \
		state_tmp="$@/.build-state.tmp"; \
		printf '%s\n' "BUILD_PROFILE=$(BUILD_PROFILE)" > "$$state_tmp"; \
		printf '%s\n' "TOOLCHAIN_CFLAGS=$(TOOLCHAIN_CFLAGS)" >> "$$state_tmp"; \
		printf '%s\n' "TOOLCHAIN_LDFLAGS=$(TOOLCHAIN_LDFLAGS)" >> "$$state_tmp"; \
		printf '%s\n' "CONFIGURE_ARGS=$$configure_args" >> "$$state_tmp"; \
		if [ -d "$@/build" ] && { [ ! -f "$@/build/$(BUILD_STATE_FILE)" ] || ! cmp -s "$@/build/$(BUILD_STATE_FILE)" "$$state_tmp"; }; then \
			echo "Cleaning $@ due to build configuration change"; \
			$(MAKE) -C $@ clean ROOT_BUILD_DIR="$(ROOT_BUILD_DIR)" CFLAGS="$(TOOLCHAIN_CFLAGS)" LDFLAGS="$(TOOLCHAIN_LDFLAGS)" || exit $$?; \
		fi; \
		$(MAKE) -C $@ ROOT_BUILD_DIR="$(ROOT_BUILD_DIR)" CFLAGS="$(TOOLCHAIN_CFLAGS)" LDFLAGS="$(TOOLCHAIN_LDFLAGS)" && \
		$(MAKE) -C $@ install ROOT_BUILD_DIR="$(ROOT_BUILD_DIR)" CFLAGS="$(TOOLCHAIN_CFLAGS)" LDFLAGS="$(TOOLCHAIN_LDFLAGS)" && \
		mkdir -p "$@/build" && \
		mv "$$state_tmp" "$@/build/$(BUILD_STATE_FILE)"; \
	else \
		echo "Skipping $@: no Makefile available after configure"; \
	fi

clean cleanconf:
	@for dir in $(BUILD_PROJECTS); do \
		if [ -f "$$dir/configure.ac" ]; then \
			configure_args=""; \
			case "$$dir" in \
				libElaraFormat) configure_args="$(LIBELARAFORMAT_CONFIGURE_FLAGS)" ;; \
				libElaraData) configure_args="$(LIBELARADATA_CONFIGURE_FLAGS)" ;; \
			esac; \
			if [ ! -x "$$dir/configure" ]; then \
				echo "Generating $$dir/configure"; \
				(cd "$$dir" && autoreconf -fi) || exit $$?; \
			fi; \
			echo "Configuring $$dir"; \
			(cd "$$dir" && ./configure $$configure_args) || exit $$?; \
		fi; \
		if [ -f "$$dir/Makefile" ]; then \
			$(MAKE) -C $$dir $@ ROOT_BUILD_DIR="$(ROOT_BUILD_DIR)" CFLAGS="$(TOOLCHAIN_CFLAGS)" LDFLAGS="$(TOOLCHAIN_LDFLAGS)" || exit $$?; \
		fi; \
	done

install:
	@if [ ! -d "$(ROOT_BUILD_DIR)/include" ] && [ ! -d "$(ROOT_BUILD_DIR)/lib" ] && [ ! -d "$(ROOT_BUILD_DIR)/bin" ] && [ ! -d "$(ROOT_BUILD_DIR)/share" ]; then \
		echo "Missing staged artifacts under $(ROOT_BUILD_DIR). Run make or ./build.sh first."; \
		exit 1; \
	fi
	@for subdir in bin include lib share; do \
		src="$(ROOT_BUILD_DIR)/$$subdir"; \
		if [ -d "$$src" ]; then \
			find "$$src" -type f | while IFS= read -r source_path; do \
				relative_path="$${source_path#$(ROOT_BUILD_DIR)/}"; \
				dest_path="$(INSTALL_ROOT_DIR)/$$relative_path"; \
				mkdir -p "$$(dirname "$$dest_path")"; \
				cp "$$source_path" "$$dest_path" || exit $$?; \
			done || exit $$?; \
		fi; \
	done

remove:
	@for subdir in bin include lib share; do \
		src="$(ROOT_BUILD_DIR)/$$subdir"; \
		if [ -d "$$src" ]; then \
			find "$$src" -type f | while IFS= read -r source_path; do \
				relative_path="$${source_path#$(ROOT_BUILD_DIR)/}"; \
				dest_path="$(INSTALL_ROOT_DIR)/$$relative_path"; \
				rm -f "$$dest_path" || exit $$?; \
			done || exit $$?; \
		fi; \
	done

smoke: all
	@$(SMOKE_SCRIPT)

smoke-project-builder-cli: all
	@$(SMOKE_SCRIPT)

list:
	@echo "Project order: $(PROJECT_DIRS)"
	@echo "Enabled: $(BUILD_PROJECTS)"
	@echo "Disabled: $(DISABLED_PROJECTS)"
	@echo "libElaraFormat flags: $(LIBELARAFORMAT_CONFIGURE_FLAGS)"
	@echo "libElaraData flags: $(LIBELARADATA_CONFIGURE_FLAGS)"
	@echo "Build profile: $(BUILD_PROFILE)"
	@echo "Compile flags: $(TOOLCHAIN_CFLAGS)"
	@echo "Link flags: $(TOOLCHAIN_LDFLAGS)"
	@echo "Configurable: $(CONFIGURE_DIRS)"
	@echo "Buildable now: $(BUILDABLE_DIRS)"
	@echo "Build stage root: $(ROOT_BUILD_DIR)"
	@echo "Install root: $(INSTALL_ROOT_DIR)"
