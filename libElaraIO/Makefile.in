NAME=libelaraio
CC=@CC@
DEFS = @DEFS@
ROOT_BUILD_DIR?=$(abspath ../build)
STAGE_INCLUDE_DIR=$(ROOT_BUILD_DIR)/include
STAGE_LIB_DIR=$(ROOT_BUILD_DIR)/lib
STD_CFLAGS=@ARCH@ -c @DEBUG_FLAGS@ -I$(shell pwd) -I$(STAGE_INCLUDE_DIR) -I/usr/local/include/libxml2 $(DEFS)
STD_LDFLAGS=
SOURCES=$(shell for file in `@TOOLPATH@find ./$(NAME) \( -name x_* @EXCLUDE@ \) -prune -o -type f -name '*.cpp' -print`;do echo $$file; done)
HEADERS=$(shell for file in `@TOOLPATH@find ./$(NAME) \( -name x_* @EXCLUDE@ \) -prune -o -type f -name '*.h' -print`;do echo $$file; done)
OBJECTS=$(subst $(NAME),build,$(SOURCES:.cpp=.o))
BUILDPATH=./build
INSTALL_HEADER_PATH=$(STAGE_INCLUDE_DIR)/$(NAME)
INSTALL_LIB_PATH=$(STAGE_LIB_DIR)
DST_HEADERS=$(subst ./$(NAME),$(INSTALL_HEADER_PATH),$(HEADERS))
STATIC_LIBRARY=$(NAME).a
STATIC_LIBRARY_PATH=$(BUILDPATH)/$(STATIC_LIBRARY)
COPIED_CONFIG=./$(NAME)/config.h

all: $(SOURCES) $(STATIC_LIBRARY_PATH)
	
$(STATIC_LIBRARY_PATH): $(OBJECTS)
	ar rcs $@ $(OBJECTS)

$(BUILDPATH)/%.o: ./$(NAME)/%.cpp $(COPIED_CONFIG)
	+@[ -d $(dir $@) ] || mkdir -p $(dir $@)
	$(CC) $(STD_CFLAGS) $(CFLAGS) $< -o $@

$(COPIED_CONFIG): config.h
	cp config.h ./$(NAME)/config.h

install:
	@for header in $(HEADERS); do \
		rel="$${header#./$(NAME)/}"; \
		dst="$(INSTALL_HEADER_PATH)/$$rel"; \
		[ -d "$$(dirname "$$dst")" ] || mkdir -p "$$(dirname "$$dst")"; \
		cp "$$header" "$$dst" || exit $$?; \
	done
	mkdir -p $(INSTALL_LIB_PATH)
	cp $(STATIC_LIBRARY_PATH) $(INSTALL_LIB_PATH)/$(STATIC_LIBRARY)

clean:
	rm -Rf $(BUILDPATH)/*.o
	rm -f $(STATIC_LIBRARY_PATH)

remove:
	rm -Rf $(INSTALL_HEADER_PATH)
	rm -f $(INSTALL_LIB_PATH)/$(STATIC_LIBRARY)

cleanconf:
	rm -Rf config.status
	rm -f config.log
	rm -f Makefile
