NAME=libelaraparallelassembly
CC=@CC@
AR=ar
DEFS=@DEFS@
ROOT_BUILD_DIR?=$(abspath ../build)
STAGE_INCLUDE_DIR=$(ROOT_BUILD_DIR)/include
STAGE_LIB_DIR=$(ROOT_BUILD_DIR)/lib
STAGE_SHARE_DIR=$(ROOT_BUILD_DIR)/share/$(NAME)
STAGE_E_DIR=$(ROOT_BUILD_DIR)/e
BUILDPATH=./build
INSTALL_HEADER_PATH=$(STAGE_INCLUDE_DIR)/$(NAME)
INSTALL_LIB_PATH=$(STAGE_LIB_DIR)
INSTALL_E_PATH=$(STAGE_E_DIR)
STATIC_LIBRARY=$(NAME).a
LEGACY_SHARED=libepa_kernel.so

RM ?= rm -f
MKDIR ?= mkdir -p
MAKE ?= make
PYTHON ?= python3

STD_CFLAGS=@ARCH@ -std=gnu11 -c -fPIC -I$(shell pwd) -I./src -I$(STAGE_INCLUDE_DIR) $(DEFS)
PROJECT_CFLAGS=$(filter-out -std=gnu++11,$(CFLAGS))
PROJECT_LDFLAGS=$(LDFLAGS)
EPA_FEATURE_DEFS=-D_POSIX_C_SOURCE=200809L -D_DEFAULT_SOURCE

SRC_DIR=./src
TOOLS_SRC_DIR=./tools
UNIT_DIR=./unittests
E_DIR=./e

SOURCES=$(shell @TOOLPATH@find $(SRC_DIR) -type f -name '*.c' ! -path './src/atomic_tasks/*' ! -path './src/threads/epa_thread_pool.c' -print)
HEADERS=$(shell for file in `@TOOLPATH@find $(SRC_DIR) -type f \( -name '*.h' -o -name '*.x' \) -print`; do echo $$file; done)
DOCS=$(shell for file in `@TOOLPATH@find ./docs -type f -print`; do echo $$file; done)
E_STDLIB=$(shell for file in `@TOOLPATH@find $(E_DIR)/common -type f -name '*.em' -print 2>/dev/null`; do echo $$file; done)
OBJECTS=$(patsubst ./src/%.c,$(BUILDPATH)/src/%.o,$(SOURCES))

TOOLS_BUILD=$(BUILDPATH)/tools
EPAASM_REPL=$(TOOLS_BUILD)/epa_asm_repl
EPAASM_REPL_OBJS=$(TOOLS_BUILD)/epa_asm_repl.o $(TOOLS_BUILD)/epa_asm_compiler.o
CUDA_BUILD=$(BUILDPATH)/cuda
CUDA_SMOKE_OBJ=$(CUDA_BUILD)/epa_cuda_smoke.o

SHARED_LDLIBS=-pthread -lglfw -lGL -ldl -lrt -lm

.PHONY: all install clean remove cleanconf isa-lint legacy-shared tools unit clean-unit e epa-build clean-e test cuda-build cuda-run

all: $(STATIC_LIBRARY)

isa-lint:
	$(PYTHON) scripts/isa_lint.py

$(STATIC_LIBRARY): $(OBJECTS)
	@$(MKDIR) $(BUILDPATH)
	$(AR) rcs $(BUILDPATH)/$@ $(OBJECTS)

$(BUILDPATH)/src/%.o: ./src/%.c
	@$(MKDIR) $(dir $@)
	$(CC) $(STD_CFLAGS) $(PROJECT_CFLAGS) $< -o $@

legacy-shared: isa-lint $(OBJECTS)
	@$(MKDIR) $(BUILDPATH)
	$(CC) -shared $(PROJECT_LDFLAGS) -o $(BUILDPATH)/$(LEGACY_SHARED) $(OBJECTS) $(SHARED_LDLIBS)

tools: $(EPAASM_REPL)

$(EPAASM_REPL): $(EPAASM_REPL_OBJS)
	@$(MKDIR) $(TOOLS_BUILD)
	$(CC) -o $@ $(EPAASM_REPL_OBJS)

$(TOOLS_BUILD)/epa_asm_repl.o: $(TOOLS_SRC_DIR)/epa_asm_repl.c
	@$(MKDIR) $(TOOLS_BUILD)
	$(CC) -std=gnu11 $(EPA_FEATURE_DEFS) -I./src $(PROJECT_CFLAGS) -c $< -o $@

$(TOOLS_BUILD)/epa_asm_compiler.o: $(SRC_DIR)/epa_asm_compiler.c
	@$(MKDIR) $(TOOLS_BUILD)
	$(CC) -std=gnu11 $(EPA_FEATURE_DEFS) -I./src $(PROJECT_CFLAGS) -c $< -o $@

unit:
	@$(MAKE) -f $(UNIT_DIR)/Makefile \
		PYTHON="$(PYTHON)" \
		CC="$(CC)" \
		CFLAGS="$(filter-out -std=gnu++11,$(PROJECT_CFLAGS)) -std=gnu11 $(EPA_FEATURE_DEFS) -I$(shell pwd)/src -I$(shell pwd)/unittests" \
		LDFLAGS="" \
		LDLIBS="-ldl -lm" \
		unit_runner

clean-unit:
	@$(MAKE) -f $(UNIT_DIR)/Makefile clean-unit

e:
	@$(MAKE) -C $(E_DIR) \
		CC="$(CC)" \
		CFLAGS="-std=gnu11 $(EPA_FEATURE_DEFS) $(filter-out -std=gnu++11,$(PROJECT_CFLAGS))"

epa-build:
	@$(MAKE) -C $(E_DIR) \
		CC="$(CC)" \
		CFLAGS="-std=gnu11 $(EPA_FEATURE_DEFS) $(filter-out -std=gnu++11,$(PROJECT_CFLAGS))" \
		epa-build

clean-e:
	@$(MAKE) -C $(E_DIR) clean

test: legacy-shared
	@$(MAKE) -f $(UNIT_DIR)/Makefile \
		PYTHON="$(PYTHON)" \
		CC="$(CC)" \
		CFLAGS="$(filter-out -std=gnu++11,$(PROJECT_CFLAGS)) -std=gnu11 $(EPA_FEATURE_DEFS) -I$(shell pwd)/src -I$(shell pwd)/unittests" \
		LDFLAGS="" \
		LDLIBS="-ldl -lm" \
		ctests
	@echo "Running EPA unit tests"
	$(BUILDPATH)/unittests/epa_unit_runner $(BUILDPATH)/$(LEGACY_SHARED) $(UNIT_DIR)/tests 5000000

cuda-build:
	@if command -v nvcc >/dev/null 2>&1; then \
		$(MKDIR) $(CUDA_BUILD); \
		echo "Building CUDA EPA smoke object"; \
		nvcc -std=c++14 -dc -I$(shell pwd) -I./src -DEPA_ENABLE_CUDA=1 src/cuda/epa_cuda_smoke.cu -o $(CUDA_SMOKE_OBJ); \
	else \
		echo "CUDA build skipped: nvcc not found"; \
	fi

cuda-run: cuda-build
	@if ! command -v nvcc >/dev/null 2>&1; then \
		echo "CUDA run skipped: nvcc not found"; \
	elif ! command -v nvidia-smi >/dev/null 2>&1; then \
		echo "CUDA run skipped: nvidia-smi not found"; \
	elif ! nvidia-smi -L >/dev/null 2>&1; then \
		echo "CUDA run skipped: no CUDA device available"; \
	else \
		echo "CUDA smoke target is compile-only for now: $(CUDA_SMOKE_OBJ)"; \
	fi

install: all
	@for header in $(HEADERS); do \
		rel="$${header#./src/}"; \
		dst="$(INSTALL_HEADER_PATH)/$$rel"; \
		[ -d "$$(dirname "$$dst")" ] || mkdir -p "$$(dirname "$$dst")"; \
		cp "$$header" "$$dst" || exit $$?; \
	done
	mkdir -p $(INSTALL_LIB_PATH)
	cp $(BUILDPATH)/$(STATIC_LIBRARY) $(INSTALL_LIB_PATH)/$(STATIC_LIBRARY)
	@if [ -n "$(DOCS)" ]; then \
		for doc in $(DOCS); do \
			rel="$${doc#./docs/}"; \
			dst="$(STAGE_SHARE_DIR)/docs/$$rel"; \
			[ -d "$$(dirname "$$dst")" ] || mkdir -p "$$(dirname "$$dst")"; \
			cp "$$doc" "$$dst" || exit $$?; \
		done; \
	fi
	@if [ -n "$(E_STDLIB)" ]; then \
		for module in $(E_STDLIB); do \
			rel="$${module#$(E_DIR)/}"; \
			dst="$(INSTALL_E_PATH)/$$rel"; \
			[ -d "$$(dirname "$$dst")" ] || mkdir -p "$$(dirname "$$dst")"; \
			cp "$$module" "$$dst" || exit $$?; \
		done; \
	fi

clean:
	rm -rf $(BUILDPATH)

remove:
	rm -rf $(INSTALL_HEADER_PATH)
	rm -rf $(INSTALL_E_PATH)
	rm -f $(INSTALL_LIB_PATH)/$(STATIC_LIBRARY)
	rm -rf $(STAGE_SHARE_DIR)

cleanconf:
	rm -rf config.status autom4te.cache
	rm -f config.log config.h Makefile
