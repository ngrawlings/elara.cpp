; fmt_log_demo.epaasm
; Demo: LOAD_CONST -> FMT -> LOG

.CONST_STR 0 "Hello {d}, hex={x}, char={c}\n"

; --------------------------
; Kernel (block 0)
; --------------------------
ENTRY_START 0 0 0 4096

  ; Run worker 1 once; it will format + log then halt.
  ENTRY_EXEC 1

  ; Wait until worker signals done.
  WAIT_ON_SYNC
  SIGNAL ; This hands control back to the host, if worker 0 invokes a signal all tickers are halted and control exits to host

ENTRY_END


; --------------------------
; Worker (block 1)
; --------------------------
ENTRY_START 1 0 0 4096

  ; Load template const string #0 into regs
  LOAD_CONST 0

  ; Push args for {d} {x} {c}
  PUSH 123
  PUSH 255
  PUSH 65

  ; Format using 3 stack args
  FMT 3

  ; Log the resulting string ref in (r0,r1,r2)
  LOG r0

  ; If LOG isn’t implemented yet, use this instead and print in host BREAK hook:
  ; BREAK 1

  ; Notify kernel and halt
  SYNC
  
ENTRY_END

END
