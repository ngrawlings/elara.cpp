{
  "elara_ui_protocol": 1,
  "window": {
    "title": "libElaraUI Demo",
    "width": 800,
    "height": 600,
    "backend_id": "org.elara.ui.demo"
  },
  "theme": {
    "mode": "light"
  },
  "root": {
    "content": "demo.tabs",
    "popup": "demo.popup"
  },
  "widgets": [
    {
      "id": "demo.popup",
      "type": "elara.widgets.popup",
      "items": [
        { "id": "file.new", "label": "New" },
        { "id": "file.open", "label": "Open" },
        { "id": "file.save", "label": "Save" },
        { "id": "file.quit", "label": "Quit" }
      ]
    },
    {
      "id": "demo.tabs",
      "type": "elara.widgets.tabs",
      "tabs": [
        {
          "title": "Surface",
          "widget": {
            "id": "demo.surface",
            "type": "demo.widgets.surface_panel"
          }
        },
        {
          "title": "Widgets",
          "widget": {
            "id": "demo.widgets.grid",
            "type": "elara.layouts.grid",
            "columns": [
              { "mode": "exact", "size": 24 },
              { "mode": "fill" },
              { "mode": "exact", "size": 160 },
              { "mode": "exact", "size": 24 }
            ],
            "rows": [
              { "mode": "exact", "size": 24 },
              { "mode": "exact", "size": 46 },
              { "mode": "exact", "size": 38 },
              { "mode": "exact", "size": 38 },
              { "mode": "exact", "size": 38 },
              { "mode": "fill" },
              { "mode": "exact", "size": 24 }
            ],
            "children": [
              {
                "id": "demo.widgets.title",
                "type": "demo.widgets.label",
                "cell": { "column": 1, "row": 1 },
                "properties": {
                  "text": "Grid layout demo: label + button",
                  "font_size": 16
                }
              },
              {
                "id": "demo.widgets.button",
                "type": "demo.widgets.button",
                "cell": { "column": 2, "row": 1 },
                "properties": {
                  "text": "Press Me",
                  "action": "grid.demo.press"
                }
              },
              {
                "id": "demo.widgets.input_label",
                "type": "demo.widgets.label",
                "cell": { "column": 1, "row": 2 },
                "properties": {
                  "text": "Name:",
                  "font_size": 14
                }
              },
              {
                "id": "demo.widgets.input",
                "type": "demo.widgets.text_input",
                "cell": { "column": 2, "row": 2 },
                "properties": {
                  "placeholder": "type here later",
                  "font_size": 14
                }
              },
              {
                "id": "demo.widgets.check",
                "type": "elara.widgets.checkbox",
                "cell": { "column": 1, "row": 3 },
                "properties": {
                  "text": "Enable numeric increment",
                  "checked": true,
                  "font_size": 14
                }
              },
              {
                "id": "demo.widgets.spinner",
                "type": "elara.widgets.spinner",
                "cell": { "column": 2, "row": 3 },
                "properties": {
                  "min": 0,
                  "max": 10,
                  "value": 3,
                  "step": 1,
                  "font_size": 14
                }
              },
              {
                "id": "demo.widgets.hslider",
                "type": "elara.widgets.slider",
                "cell": { "column": 1, "row": 5 },
                "properties": {
                  "orientation": "horizontal",
                  "min": 0,
                  "max": 100,
                  "value": 42,
                  "step": 1
                }
              },
              {
                "id": "demo.widgets.vslider",
                "type": "elara.widgets.slider",
                "cell": { "column": 2, "row": 5 },
                "properties": {
                  "orientation": "vertical",
                  "min": 0,
                  "max": 1,
                  "value": 0.65,
                  "step": 0.05
                }
              },
              {
                "id": "demo.widgets.radio.alpha",
                "type": "elara.widgets.radio_button",
                "cell": { "column": 1, "row": 4 },
                "properties": {
                  "text": "Mode A",
                  "group": "demo.mode",
                  "checked": true,
                  "font_size": 14
                }
              },
              {
                "id": "demo.widgets.radio.beta",
                "type": "elara.widgets.radio_button",
                "cell": { "column": 2, "row": 4 },
                "properties": {
                  "text": "Mode B",
                  "group": "demo.mode",
                  "checked": false,
                  "font_size": 14
                }
              }
            ]
          }
        },
        {
          "title": "Density map",
          "widget": {
            "id": "demo.density",
            "type": "elara.widgets.density_map",
            "properties": {
              "base_capacity": 8,
              "capacity_multiplier": 2,
              "layer_count": 16
            },
            "demo_data": {
              "type": "modulo_sequence",
              "sample_count": 65536,
              "sample_multiplier": 2
            }
          }
        },
        {
          "title": "Chart",
          "widget": {
            "id": "demo.chart",
            "type": "elara.widgets.multi_axis_line_chart",
            "properties": {
              "title": "Orders and latency by sample",
              "show_points": true
            },
            "demo_data": {
              "axes": [
                {
                  "id": "orders",
                  "label": "orders/min",
                  "side": "left",
                  "min": 0,
                  "max": 240,
                  "color": [0.15, 0.55, 0.95]
                },
                {
                  "id": "latency",
                  "label": "latency ms",
                  "side": "right",
                  "min": 0,
                  "max": 700,
                  "color": [0.95, 0.45, 0.20]
                }
              ],
              "series": [
                {
                  "id": "created",
                  "label": "created orders",
                  "axis": "orders",
                  "color": [0.13, 0.67, 0.94],
                  "values": [88, 102, 116, 124, 138, 149, 162, 176, 184, 196, 214, 228]
                },
                {
                  "id": "fulfilled",
                  "label": "fulfilled orders",
                  "axis": "orders",
                  "color": [0.12, 0.82, 0.48],
                  "values": [72, 86, 95, 109, 121, 132, 146, 153, 168, 177, 191, 205]
                },
                {
                  "id": "p95",
                  "label": "p95 latency",
                  "axis": "latency",
                  "color": [0.93, 0.40, 0.18],
                  "values": [410, 384, 360, 332, 318, 290, 304, 346, 372, 420, 465, 492]
                }
              ]
            }
          }
        },
        {
          "title": "Editor",
          "widget": {
            "id": "demo.editor",
            "type": "elara.widgets.rich_text_edit",
            "properties": {
              "font_size": 14,
              "text": "# Elara Notes\n## Build status\n- RPC server is live\n- Sliders are now primitive widgets\n- Chart tab renders dual-axis sample data\n\n## Next step\nUse this editor as the basis for higher-level document widgets.\n\nHorizontal scrolling is handled by the child slider when lines grow beyond the viewport."
            }
          }
        }
      ]
    }
  ]
}
