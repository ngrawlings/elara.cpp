{
    "Clean": "./tools/clean_all_builds.sh",
    "Build & Install": "./build.sh && sudo ./install.sh",
    "Install": "sudo ./install.sh",
    "UI Server": "/usr/local/bin/elaraui-server",
    "Debug UI Server": "gdb /usr/local/bin/elaraui-server",
    "UI Client": "cd /home/nyhl/workspace/elara.cpp/libElaraUiRpc && ./build/bin/libelarauirpc-client 127.0.0.1 18777 /home/nyhl/workspace/elara.cpp/libElaraUI/elara_ui_layout.json",
    "EPA IDE": "cd ./epa-ide && ./run-client.sh --ai-rpc-port 18792 --repl --snapshot-out snapshots/ui.json --event-log /tmp/client-events.jsonl",
    "Mount Elara OS Root": "demos/elara-os/tools/mount_virtual_root.sh",
    "Install Elara OS Files": "demos/elara-os/tools/install_compiled_os_files_to_mounted_root.sh",
    "Launch Elara OS": "demos/elara-os/tools/launch_elara_os.sh",
    "Unmount Elara OS Root": "demos/elara-os/tools/unmount_virtual_root.sh",
    "Orange Fortress": "cd /home/nyhl/workspace/elara.cpp/demos/orange-fortress && ./launch-debug.sh",
    "Orange Fortress GDB": "cd /home/nyhl/workspace/elara.cpp/demos/orange-fortress && ./launch-gdb.sh",
    "Kill all": "./killall.sh"
}
